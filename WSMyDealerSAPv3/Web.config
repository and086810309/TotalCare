<?xml version="1.0"?>
<configuration>
  <appSettings>
    <add key="usuarioBaseDatos" value="mydealer"/>
    <!-- usuario de la base de datos SAP -->
    <add key="passwordBaseDatos" value="sql123@"/>
    <!-- clave de acceso a la base de datos SAP  -->
    <add key="usuarioSAP" value="manager"/>
    <!-- usuario sap -->
    <add key="passwordSAP" value="xypxa"/>
    <!-- clave de usuario sap -->
    <add key="nombreBaseDatos" value="Z_PRUEBA_SBO_NUTRI_PROD"/>
    <!-- nombre de la base de datos SAP -->
    <add key="ipBaseDatos" value="172.31.34.244"/>
    <!-- ip de la base de datos SAP -->
    <add key="servidorSAPDIAPI" value="srv-db-02"/>
    <!-- nombre/IP del servidor SQL tal como aparece registrado en SLD para DI API; si en SAP aparece un hostname, usar ese hostname aqui -->
    <add key="puertoBaseDatos" value="1433"/>
    <!-- puerto de la base de datos SAP -->
    <add key="ipServidorLicencia" value="172.31.34.243"/>
    <!-- ip de la base de datos SAP -->
    <add key="puertoServidorLicencia" value="30000"/>
    <!-- puerto del servidor de licencias -->
    <add key="servidorSLD" value="https://172.31.34.243:40000"/>
    <!-- servidor SLD para DI API; el puerto 30000 corresponde al License Server -->
    <add key="tipoBaseDatos" value="dst_MSSQL2019"/>
    <!-- tipo de base de datos (ver tipos definidos en la documentacion sap -->
    <add key="separadorDecimal" value="P"/>
    <!-- (P|C) Separador decimal para conversiones numericas, si es P, todas las comas se reemplazan por punto -->
    <add key="paisSistema" value="EC"/>
    <!-- (EC|CL) Pais, define comportamientos especiales -->
    <add key="aprobacion" value="true"/>
    <!-- (true|false) Aprobacion, indica si deben enviarse o no parametros de aprobacion de pedidos a SAP -->
    <add key="serieRetencion" value="0"/>
    <!-- La serie utilizada para las retenciones (usada en cobranzas para la forma de pago retencion -->
    <add key="glosaNotaCredito" value="DESCUENTO EN VENTAS GOLDEN BEAR"/>
    <add key="cuetaNotaCredito" value="101010100000000"/>
    <add key="cuetaNotaAnticipoCobranza" value="_SYS00000001497"/>
  </appSettings>
  <!--
    Para obtener una descripción de los cambios de web.config, vea http://go.microsoft.com/fwlink/?LinkId=235367.

    Los siguientes atributos se pueden establecer en la etiqueta <httpRuntime>.
      <system.Web>
        <httpRuntime targetFramework="4.8" />
      </system.Web>
  -->
  <system.web>
    <compilation debug="true" defaultLanguage="c#" targetFramework="4.8"/>
    <sessionState mode="Off"/>
    <pages controlRenderingCompatibilityVersion="4.0"/>
  </system.web>
</configuration>
